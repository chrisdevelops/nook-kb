{
  "name": "@nook/mem",
  "version": "0.5.0",
  "private": true,
  "type": "module",
  "engines": {
    "bun": ">=1.2.0"
  },
  "files": [
    "src",
    "!src/**/*.test.ts",
    "README.md"
  ],
  "bin": {
    "mem": "src/index.ts"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.5.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.49",
    "ajv": "^8.20.0",
    "cac": "^7.0.0",
    "ulid": "^3.0.2"
  }
}
